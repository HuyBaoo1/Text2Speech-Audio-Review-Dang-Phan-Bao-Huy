OPENAI_API_KEY=put-your-openai-api-key-here
GROQ_API_KEY=put-your-groq-api-key-here
DEEPGRAM_API_KEY=put-your-deepgram-api-key-here
GEMINI_API_KEY=put-your-gemini-api-key-here
ELEVENLABS_API_KEY=put-your-elevenlabs-api-key-here
ASSEMBLYAI_API_KEY=put-your-assemblyai-api-key-here
AZURE_SPEECH_KEY=put-your-azure-speech-key-here
AZURE_SPEECH_REGION=put-your-azure-region-here
GOOGLE_APPLICATION_CREDENTIALS=path-to-google-service-account.json
GOOGLE_CLOUD_PROJECT=put-your-google-cloud-project-id-here
GOOGLE_CLOUD_LOCATION=global
AWS_ACCESS_KEY_ID=put-your-aws-access-key-id-here
AWS_SECRET_ACCESS_KEY=put-your-aws-secret-access-key-here
AWS_REGION=ap-southeast-1

ASR_LANGUAGE=vi

# ASR model priority from current Vietnamese benchmark + paid candidates.
# Format: provider:model. Keep this order when running the next evaluation round.
ASR_MODEL_PRIORITY=openai:gpt-4o-mini-transcribe,openai:gpt-4o-transcribe,groq:whisper-large-v3-turbo,google:chirp_3,deepgram:nova-3,azure:azure-short-audio,elevenlabs:scribe_v2,aws:transcribe-vi-vn,assemblyai:universal-3-pro,gemini:gemini-2.5-flash,local-whisper:vinai/PhoWhisper-small

# Current best measured model on audio_samples/matched_audio.
ASR_BASELINE_MODEL=openai:gpt-4o-mini-transcribe

# Paid models to benchmark next before production selection.
ASR_PAID_CANDIDATES=openai:gpt-4o-transcribe,google:chirp_3,azure:azure-short-audio,deepgram:nova-3,elevenlabs:scribe_v2,assemblyai:universal-3-pro,aws:transcribe-vi-vn

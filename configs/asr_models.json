{
  "sample_limit": 100,
  "dataset_folder": "audio_samples/matched_audio",
  "models": [
    {
      "provider": "local-whisper",
      "model": "openai/whisper-small",
      "role": "fast local baseline"
    },
    {
      "provider": "local-whisper",
      "model": "openai/whisper-medium",
      "role": "stronger local baseline"
    },
    {
      "provider": "local-whisper",
      "model": "vinai/PhoWhisper-small",
      "role": "free local Vietnamese baseline"
    },
    {
      "provider": "local-whisper",
      "model": "vinai/PhoWhisper-medium",
      "role": "free local stronger Vietnamese baseline"
    },
    {
      "provider": "openai",
      "model": "gpt-4o-mini-transcribe",
      "role": "paid API/free-quota baseline",
      "env": "OPENAI_API_KEY"
    },
    {
      "provider": "groq",
      "model": "whisper-large-v3-turbo",
      "role": "free-quota hosted Whisper baseline",
      "env": "GROQ_API_KEY"
    },
    {
      "provider": "deepgram",
      "model": "nova-3",
      "role": "free-quota hosted production ASR baseline",
      "env": "DEEPGRAM_API_KEY",
      "language": "vi"
    },
    {
      "provider": "gemini",
      "model": "gemini-2.5-flash",
      "role": "free-tier multimodal transcription baseline",
      "env": "GEMINI_API_KEY",
      "language": "Vietnamese"
    },
    {
      "provider": "gemini",
      "model": "gemini-2.5-pro",
      "role": "Gemini 2.5 Pro multimodal transcription",
      "env": "GEMINI_API_KEY",
      "language": "Vietnamese"
    },
    {
      "provider": "gemini",
      "model": "gemini-3",
      "role": "Gemini 3 multimodal transcription",
      "env": "GEMINI_API_KEY",
      "language": "Vietnamese"
    },
    {
      "provider": "gemini",
      "model": "gemini-3.1-pro",
      "role": "Gemini 3.1 Pro multimodal transcription",
      "env": "GEMINI_API_KEY",
      "language": "Vietnamese"
    },
    {
      "provider": "gemini",
      "model": "gemini-3.5-flash",
      "role": "Gemini 3.5 Flash multimodal transcription",
      "env": "GEMINI_API_KEY",
      "language": "Vietnamese"
    },
    {
      "provider": "gemini",
      "model": "gemini-3.1-flash-lite",
      "role": "Gemini 3.1 Flash Lite lightweight multimodal transcription",
      "env": "GEMINI_API_KEY",
      "language": "Vietnamese"
    },
    {
      "provider": "iflytek",
      "model": "iat-niche",
      "role": "iFLYTEK short speech recognition baseline for Vietnamese/small-language ASR",
      "env": "IFLYTEK_API_KEY",
      "required_env": ["IFLYTEK_APP_ID", "IFLYTEK_API_KEY", "IFLYTEK_API_SECRET"],
      "language": "vi"
    },
    {
      "provider": "elevenlabs",
      "model": "scribe_v2",
      "role": "free-quota speech-to-text baseline",
      "env": "ELEVENLABS_API_KEY",
      "language": "vie"
    },
    {
      "provider": "azure",
      "model": "azure-short-audio",
      "role": "Azure Speech free-tier baseline",
      "env": "AZURE_SPEECH_KEY",
      "language": "vi-VN"
    }
  ]
}
